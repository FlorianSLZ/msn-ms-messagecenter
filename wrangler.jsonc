{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ms-messagecenter",
  "compatibility_date": "2026-06-15",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/index.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "durable_objects": {
    "bindings": [
      { "name": "RL_DO", "class_name": "RateLimiter" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["RateLimiter"] }
  ]
}
